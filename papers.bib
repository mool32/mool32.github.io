  author   = {Spiro, Theodor},
  year     = {2026},
  howpublished = {Technical report},
  code     = {https://mool32.github.io/nn-as-sensor/},
  abstract = {Honest negative result. A pre-registered test (A and B and C and D, leave-donors-out) of whether an autoencoder's unsupervised fit can recover donor age from immune scRNA-seq (GSE233321, 167 donors). The latent never beats a matched linear PCA at recovering age (0/2 across two seeds times latent dimensions) and training erodes the signal; a synthetic positive control localises the regime where the method would win - high linear rank, low intrinsic dimension - which single-cell data does not occupy. The unsupervised latent independently re-derives the perceptome eigenspace (cross-validated CCA, all p=0.001) but not its aging axis (orthogonal to the reference inflammaging direction).},
  teaser   = {Honest negative result. A pre-registered test (A∧B∧C∧D, leave-donors-out) of whether an autoencoder's unsupervised fit can recover donor age from immune scRNA-seq (GSE233321, 167 donors). The latent never beats a matched linear PCA at recovering age (0/2 across two seeds × latent dims) and training erodes the signal; a synthetic positive control localises the regime where the method would win — high linear rank, low intrinsic dimension — which single-cell data does not occupy. The unsupervised latent independently re-derives the perceptome eigenspace (cross-validated CCA, all p = 0.001) but not its aging axis (orthogonal to the reference inflammaging direction).},
  bibtex_show = {true},
  order    = {14},
  venue    = {Technical report},
  stage    = {in-progress},
  status   = {pre-registered negative; prototype confirmed, write-up in progress}
}
