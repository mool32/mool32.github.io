@software{spiro2026perceptome,
  abbr     = {toolkit},
  title    = {perceptome: a Python toolkit for cellular perception analysis},
  author   = {Spiro, Theodor},
  year     = {2026},
  version  = {0.3},
  doi      = {10.5281/zenodo.20113468},
  url      = {https://doi.org/10.5281/zenodo.20113468},
  code     = {https://github.com/mool32/perceptome},
  abstract = {A Python toolkit treating 44 cellular signaling pathways (NF-kB, mTOR, UPR, p53, nuclear receptors, ...) as a cell's perceptual repertoire. Three capabilities other tools don't directly provide: (1) a 9-PC eigenspace derived from 154 normal human cell types (Human Protein Atlas) where any cell can be located on the same map; (2) a capacity-floor predictor that says whether a cell type and pathway will ramp under stimulus or is already saturated; (3) a validity scorecard with three null controls (random-gene panel, housekeeping, cell cycle) that catches common perturbation artifacts before interpretation. The framework underpins the cancer-convergence result reported separately (Zenodo 10.5281/zenodo.20542130): malignant cells of 25 cancers converge on the placental cytotrophoblast, a normal invasive cell state that malignancy deepens within patients. The tool implements only what the underlying multi-year pre-registered research program validated and deliberately excludes operations that were tested and falsified.},
  teaser   = {A Python toolkit treating 44 cellular signaling pathways (NF-κB, mTOR, UPR, p53, nuclear receptors, …) as a cell's perceptual repertoire. Three capabilities other tools don't directly provide: (1) a 9-PC eigenspace derived from 154 normal human cell types (Human Protein Atlas) where any cell — yours, a tumor, a drug-treated — can be located on the same map; (2) a capacity-floor predictor — given a cell type and a pathway, will it ramp under stimulus or is it already saturated; (3) a validity scorecard with three null controls (random-gene panel, housekeeping, cell cycle) that catches common perturbation artifacts before interpretation. It is the toolkit behind the cancer-convergence finding — 25 cancers converge on the placental cytotrophoblast (Zenodo 10.5281/zenodo.20542130) — and implements only what that multi-year pre-registered program validated, deliberately excluding operations that were tested and falsified.},
  selected = {true},
  bibtex_show = {true},
  order    = {1},
  venue    = {Software release (v0.3)},
  stage    = {software-release},
  status   = {public release v0.3 (May 2026)}
}


@misc{spiro2026cytotrophoblast,
  abbr     = {preprint},
  title    = {Cancers of all lineages converge on the placental cytotrophoblast, a normal invasive cell state that malignancy deepens},
  author   = {Spiro, Theodor},
  year     = {2026},
  howpublished = {Preprint (Zenodo)},
  doi      = {10.5281/zenodo.20542130},
  url      = {https://doi.org/10.5281/zenodo.20542130},
  abstract = {A coordinate system for cellular state is built from 44 transcriptional modules scored across 154 normal human cell types (Human Protein Atlas), using single-cell RNA exclusively and no cancer data; the resulting nine-dimensional eigenspace recovers known biology before any cancer is introduced. Projecting 25 quality-controlled single-cell cancer datasets, the malignant compartment of every major lineage converges onto one small region of normal-cell physiology, contracting the program space 6.3-fold relative to the cancers' near-orthogonal tissues of origin. A recurrence-and-depth ranking identifies a two-cell core: the placental cytotrophoblast -- the complexity-robust, lineage-independent anchor and the normal cell that physiologically invades, proliferates, and evades immunity -- with the megakaryocyte a lineage-restricted secondary. The state is not unique to cancer: some normal secretory epithelia (healthy lung) occupy it as fully as tumors. What is specifically malignant emerges within patients -- in matched tumor-normal pairs, malignant epithelium converges about sixfold deeper than the patient's own normal tissue (colorectal 43/46 patients, paired P < 1e-12; replicated in kidney and liver, 77/86 patients; absent in the one high-baseline tissue, lung). Cancer thus reaches a pre-existing, tissue-variable normal cell state and deepens it, linking malignancy quantitatively and geometrically to normal placental and developmental biology rather than to a uniquely cancerous program.},
  teaser   = {A coordinate map built from 44 signaling modules over 154 normal cell types — no cancer data — onto which the malignant cells of 25 cancers converge. The anchor is the placental cytotrophoblast, a normal cell state that naturally invades, proliferates, and evades immunity; within patients, malignancy deepens the state ~6× over matched normal tissue (colorectal 43/46, paired P < 10⁻¹²). Not a uniquely cancerous program but a normal placental/developmental one, pushed deeper.},
  bibtex_show = {true},
  order    = {0},
  venue    = {Preprint (Zenodo)},
  stage    = {preprint},
  selected = {true},
  headline = {true},
  status   = {preprint on Zenodo (DOI 10.5281/zenodo.20542130)}
}


